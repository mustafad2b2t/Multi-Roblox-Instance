<Window x:Class="RobloxMultiLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RobloxMultiLauncher"
        Title="Roblox Multi Instance Launcher"
        Icon="logo.png"
        Height="700" Width="1050"
        MinHeight="500" MinWidth="800"
        Background="#1e1e1e"
        Foreground="#cccccc"
        FontFamily="Segoe UI"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <Window.Resources>
        <local:PrivServerConverter x:Key="PrivServerConverter" />
        <!-- IDE Textblock Style -->
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cccccc" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!-- IDE Scrollbar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1e1e1e" />
            <Setter Property="Foreground" Value="#424242" />
        </Style>

        <!-- ToolBar Buttons (IDE Action Bar Style) -->
        <Style TargetType="Button" x:Key="ToolbarBtn">
            <Setter Property="Background" Value="#2d2d2d"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3c3c3c"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#3c3c3c"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#1e1e1e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Accent Button -->
        <Style TargetType="Button" x:Key="PrimaryBtn" BasedOn="{StaticResource ToolbarBtn}">
            <Setter Property="Background" Value="#0e639c"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#1177bb"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button -->
        <Style TargetType="Button" x:Key="DangerBtn" BasedOn="{StaticResource ToolbarBtn}">
            <Setter Property="Background" Value="#702020"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#902626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="IconBtn" BasedOn="{StaticResource ToolbarBtn}">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- IDE DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="RowBackground" Value="#1e1e1e"/>
            <Setter Property="AlternatingRowBackground" Value="#252526"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="ColumnHeaderHeight" Value="38"/>
        </Style>

        <!-- Dark ComboBox -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Border x:Name="border" Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="▼" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#cccccc" FontSize="10"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="Background" Value="#333333"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="border" Property="Background" Value="#1e1e1e"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox" x:Key="DarkComboBox">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Template="{StaticResource ComboBoxToggleButton}" Grid.Column="2" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="8,4" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#252526" BorderThickness="1" BorderBrush="#3c3c3c"/>
                                    <ScrollViewer Margin="0" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#252526"/>
                        <Setter Property="Foreground" Value="#cccccc"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#04395e"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#333333"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2a2d2e"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#04395e"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252526" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚙️" FontSize="18" Margin="0,0,10,0"/>
                    <TextBlock Text="ROBLOX LAUNCHER" FontSize="12" FontWeight="Bold" Foreground="#858585" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="📁 Open Folder" Style="{StaticResource IconBtn}" Click="BtnOpenFolder_Click" Foreground="#cccccc"/>
                    <Button Content="⚙ Settings" Style="{StaticResource IconBtn}" Click="BtnSettings_Click" Foreground="#cccccc"/>
                    <Button Content="↓ To Tray" Style="{StaticResource IconBtn}" Click="BtnMinimizeTray_Click" Foreground="#cccccc"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- Command Toolbar -->
        <Border Grid.Row="1" Background="#1e1e1e" Padding="20,16,20,4">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Top">
                <Button Content="+ Add Account" Style="{StaticResource PrimaryBtn}" Click="BtnAdd_Click"/>
                
                <Rectangle Width="1" Fill="#333333" Margin="8,4,16,12"/>
                
                <Button Content="▶ Launch All" Style="{StaticResource ToolbarBtn}" Foreground="#89d185" Click="BtnLaunchAll_Click"/>
                <Button Content="▶ Launch Selected" Style="{StaticResource ToolbarBtn}" Click="BtnLaunchSel_Click"/>
                <Button Content="⏹ Stop All" Style="{StaticResource DangerBtn}" Click="BtnStopAll_Click" Margin="0,0,8,8"/>
                
                <Rectangle Width="1" Fill="#333333" Margin="8,4,16,12"/>
                
                <Button Content="⊞ Auto Arrange" Style="{StaticResource ToolbarBtn}" Click="BtnArrange_Click"/>
                <Button Content="AFK All ON" Style="{StaticResource ToolbarBtn}" Click="BtnAfkAll_Click"/>
                <Button Content="AFK All OFF" Style="{StaticResource ToolbarBtn}" Click="BtnAfkNone_Click"/>
                
                <Rectangle Width="1" Fill="#333333" Margin="8,4,16,12"/>
                
                <Button Content="🗑 Remove" Style="{StaticResource ToolbarBtn}" Click="BtnRemove_Click"/>

                <Rectangle Width="1" Fill="#333333" Margin="8,4,16,12"/>

                <Button Content="🎮 Manage Games" Style="{StaticResource ToolbarBtn}" Click="BtnManageGames_Click"/>
                
                <TextBlock Text="Set Game:" Foreground="#cccccc" VerticalAlignment="Center" Margin="8,0,4,8" FontSize="11"/>
                <ComboBox x:Name="CbGlobalGame" Style="{StaticResource DarkComboBox}" Width="130" Height="32" DisplayMemberPath="Name" SelectedValuePath="PlaceId" Margin="0,0,4,8" />
                <Button Content="Apply to Selected" Style="{StaticResource ToolbarBtn}" Click="BtnSetTargetGame_Click"/>
            </WrapPanel>
        </Border>

        <!-- DataGrid Area -->
        <Border Grid.Row="2" Margin="20,0,20,20" BorderBrush="#333333" BorderThickness="1" CornerRadius="4">
            <DataGrid x:Name="DgAccounts" ItemsSource="{Binding Accounts}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="USERNAME" Binding="{Binding Username}" Width="160"/>
                    <DataGridTextColumn Header="PLACE ID" Binding="{Binding PlaceId}" Width="140"/>
                    <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="160"/>
                    <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="80"/>
                    <DataGridTemplateColumn Header="SERVER" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PrivateServerLink, Converter={StaticResource PrivServerConverter}}" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="AFK" Binding="{Binding AfkStatus}" Width="110"/>
                    
                    <!-- AFK Toggle -->
                    <DataGridTemplateColumn Header="AFK TOGGLE" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Toggle" Style="{StaticResource ToolbarBtn}" Margin="0" Padding="10,4"
                                        Tag="{Binding}" Click="BtnToggleAfk_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Row Actions -->
                    <DataGridTemplateColumn Header="ACTIONS" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="▶ Play" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0" Padding="12,4"
                                            Tag="{Binding}" Click="BtnLaunchSingle_Click"/>
                                    <Button Content="⏹ Stop" Style="{StaticResource DangerBtn}" Margin="0" Padding="12,4"
                                            Tag="{Binding}" Click="BtnStopSingle_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- VS Code Status Bar -->
        <Border Grid.Row="3" Background="#007acc" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" x:Name="TxtRobloxPath" Foreground="#ffffff" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" x:Name="TxtStatus" Text="Ready" Foreground="#ffffff" FontSize="11" VerticalAlignment="Center" Margin="20,0,0,0"/>
                <TextBlock Grid.Column="2" x:Name="TxtCounts" Foreground="#ffffff" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
