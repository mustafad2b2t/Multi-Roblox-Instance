<Window x:Class="RobloxMultiLauncher.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings — Roblox Multi Launcher"
        Height="520" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1e1e1e"
        Foreground="#cccccc"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0e639c"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
        <Style x:Key="LblStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SliderStyle" TargetType="Slider">
            <Setter Property="Foreground" Value="#0e639c"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ValueLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Width" Value="55"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BtnSave" TargetType="Button">
            <Setter Property="Background" Value="#0e639c"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="28,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#1177bb"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,20,28,28">
            <TextBlock Text="⚙ Settings" FontSize="20" Foreground="#ffffff" Margin="0,0,0,8"/>
            <Rectangle Height="1" Fill="#333333" Margin="0,0,0,8"/>

            <TextBlock Text="LAUNCH SETTINGS" Style="{StaticResource SectionHeader}"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Launch Delay (ms)" Style="{StaticResource LblStyle}"/>
                <Slider Grid.Column="1" x:Name="SliderDelay" Minimum="1000" Maximum="10000" SmallChange="100" LargeChange="500" TickFrequency="500" Style="{StaticResource SliderStyle}" ValueChanged="SliderDelay_ValueChanged"/>
                <TextBlock Grid.Column="2" x:Name="TxtDelay" Style="{StaticResource ValueLabel}"/>
            </Grid>

            <TextBlock Text="AFK SETTINGS" Style="{StaticResource SectionHeader}"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="AFK Interval Min (sec)" Style="{StaticResource LblStyle}"/>
                <Slider Grid.Column="1" x:Name="SliderAfkMin" Minimum="5" Maximum="300" SmallChange="5" LargeChange="30" Style="{StaticResource SliderStyle}" ValueChanged="SliderAfkMin_ValueChanged"/>
                <TextBlock Grid.Column="2" x:Name="TxtAfkMin" Style="{StaticResource ValueLabel}"/>
            </Grid>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="AFK Interval Max (sec)" Style="{StaticResource LblStyle}"/>
                <Slider Grid.Column="1" x:Name="SliderAfkMax" Minimum="10" Maximum="600" SmallChange="5" LargeChange="30" Style="{StaticResource SliderStyle}" ValueChanged="SliderAfkMax_ValueChanged"/>
                <TextBlock Grid.Column="2" x:Name="TxtAfkMax" Style="{StaticResource ValueLabel}"/>
            </Grid>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Mouse Movement Radius (px)" Style="{StaticResource LblStyle}"/>
                <Slider Grid.Column="1" x:Name="SliderRadius" Minimum="10" Maximum="300" SmallChange="5" LargeChange="20" Style="{StaticResource SliderStyle}" ValueChanged="SliderRadius_ValueChanged"/>
                <TextBlock Grid.Column="2" x:Name="TxtRadius" Style="{StaticResource ValueLabel}"/>
            </Grid>

            <Rectangle Height="1" Fill="#333333" Margin="0,16,0,20"/>

            <Button Content="Save Settings" Style="{StaticResource BtnSave}" HorizontalAlignment="Right" Click="Save_Click"/>
        </StackPanel>
    </ScrollViewer>
</Window>
